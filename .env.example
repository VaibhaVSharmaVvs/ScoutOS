# Copy to .env and fill in. Never commit .env.

# --- PostgreSQL ---
POSTGRES_USER=scout
POSTGRES_PASSWORD=change_me_in_local_env
POSTGRES_DB=scoutos
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Used by the backend (inside docker network, host is "postgres")
DATABASE_URL=postgresql+psycopg://scout:change_me_in_local_env@localhost:5432/scoutos

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- Backend ---
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
# Generate a real one: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change_me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- LLM (Phase 6) ---
ANTHROPIC_API_KEY=

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
