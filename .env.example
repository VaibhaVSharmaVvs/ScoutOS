# Copy to .env and fill in. Never commit .env.

# --- PostgreSQL ---
POSTGRES_USER=scout
POSTGRES_PASSWORD=change_me_in_local_env
POSTGRES_DB=scoutos
POSTGRES_HOST=localhost
# If you already run a local Postgres on 5432, set this to 5433 (or another free
# port) to avoid a silent collision — host connections would otherwise hit your
# local Postgres instead of the container. The container is always 5432 inside.
POSTGRES_PORT=5432
# Used by the backend (inside docker network, host is "postgres"). For LOCAL
# tools (alembic/etl) match POSTGRES_PORT above (e.g. localhost:5433).
DATABASE_URL=postgresql+psycopg://scout:change_me_in_local_env@localhost:5432/scoutos

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- Backend ---
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
# Generate a real one: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change_me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- LLM (Phase 6) ---
ANTHROPIC_API_KEY=

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
